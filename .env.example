# --- Postgres ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/threads
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://cache:6379/0
CACHE_TTL_FEED=30
CACHE_TTL_PROFILE=60

# --- Auth ---
JWT_SECRET=troque-em-producao
JWT_ALGORITHM=HS256
GOOGLE_CLIENT_ID=

# --- Site / CORS ---
SITE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
